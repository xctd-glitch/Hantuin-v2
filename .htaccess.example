# ===================================================================
# SRP v2.1 — Root .htaccess (di luar public_html)
# ===================================================================
# Taruh file ini di ROOT PROJECT (parent dari public_html/).
# Jika document root = public_html/, file ini opsional.
# Jika document root = project root, RENAME jadi .htaccess
# ===================================================================

# Blok directory listing
Options -Indexes
Options -MultiViews

# ===================================================================
# DENY ALL — root project tidak boleh diakses via web
# ===================================================================
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# ===================================================================
# KECUALI public_html/ — redirect ke sana
# ===================================================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Jika request ke root, forward ke public_html/
    RewriteRule ^$ public_html/index.php [L]

    # Forward semua request ke public_html/
    RewriteCond %{REQUEST_URI} !^/public_html/
    RewriteRule ^(.*)$ public_html/$1 [L]
</IfModule>
