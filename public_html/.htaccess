# ===================================================================
# SRP v2.1 — public_html/.htaccess  (production — LiteSpeed/CloudLinux)
# ===================================================================
# PHP 8.3 diset via cPanel → Select PHP Version (CloudLinux Selector).
# ===================================================================

# ── BASIC OPTIONS ────────────────────────────────────────────────
Options -Indexes
Options -MultiViews
DirectoryIndex index.php

# ── SECURITY HEADERS ─────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"

    # Hapus header yang bocorkan info server
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ── CACHING ──────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # PHP responses: no cache
    <FilesMatch "\.(php)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Static assets: cache 1 year
    <FilesMatch "\.(jpe?g|png|gif|ico|webp|avif|css|js|woff2?|ttf|eot|otf|svg)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Service worker: no cache (harus selalu fresh)
    <FilesMatch "service-worker\.js$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    </FilesMatch>

    # Manifest: cache 1 day
    <FilesMatch "manifest\.json$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>

# ── COMPRESSION ──────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE \
        text/html text/plain text/xml text/css text/javascript \
        application/javascript application/json application/xml \
        application/xhtml+xml image/svg+xml
</IfModule>

# ── LiteSpeed — disable cache untuk endpoint dinamis ─────────────
<IfModule LiteSpeed>
    CacheDisable public /api/
    CacheDisable public /decision.php
    CacheDisable public /postback.php
    CacheDisable public /login.php
    CacheDisable public /logout.php
    CacheDisable public /install.php
</IfModule>

# ── CORS — untuk API endpoints ───────────────────────────────────
<IfModule mod_headers.c>
    <FilesMatch "(api|decision|postback|data)\.php$">
        Header always set Access-Control-Allow-Origin "*"
        Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Header always set Access-Control-Allow-Headers "Content-Type, X-API-Key, X-Requested-With"
        Header always set Access-Control-Max-Age "86400"
        # Hapus COOP/CORP untuk API endpoints (cross-origin callers)
        Header always unset Cross-Origin-Opener-Policy
        Header always unset Cross-Origin-Resource-Policy
    </FilesMatch>
</IfModule>

# ── URL REWRITING / ROUTING ──────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ─── Security: blok akses ke direktori sensitif ───
    RewriteRule ^(?:\.git|\.svn|\.hg)/ - [F,L]
    RewriteRule ^(?:src|cron|backups|logs|storage|vendor)/ - [F,L]
    RewriteRule ^(?:node_modules|\.claude|tests|scripts)/ - [F,L]

    # ─── Force HTTPS (termasuk di belakang reverse proxy) ───
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteCond %{HTTP:CF-Visitor} !'"scheme":"https"'
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ─── Preflight OPTIONS ───
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(api|decision|postback|data)\.php$ - [R=204,L]

    # ─── API routing ───
    RewriteRule ^api/v1/?(.*)$ api.php/$1 [L,QSA]

    # ─── Campaign short URLs ───
    RewriteRule ^l/([a-zA-Z0-9_-]+)/?$ landing.php?user_lp=$1 [L,QSA]

    # ─── Meetup tracking entry ───
    RewriteRule ^_meetups/?$ landing.php [L,QSA]

    # ─── Clean URL aliases ───
    RewriteRule ^login/?$ login.php [L,QSA]
    RewriteRule ^landing/?$ landing.php [L,QSA]
    RewriteRule ^stats/?$ stats.php [L,QSA]
    RewriteRule ^decision/?$ decision.php [L,QSA]
    RewriteRule ^postback/?$ postback.php [L,QSA]

    # ─── Root ───
    RewriteRule ^$ index.php [L,QSA]

    # ─── Serve real files/directories as-is ───
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
</IfModule>

# ── DENY ACCESS TO SENSITIVE FILES ───────────────────────────────
<IfModule mod_authz_core.c>
    # Hidden files (dotfiles: .env, .git, .htpasswd, dll)
    <FilesMatch "^\.">
        Require all denied
    </FilesMatch>

    # Backup, temp, editor swap files
    <FilesMatch "\.(bak|backup|old|tmp|swp|swo|dist|orig|save|sql|log)$">
        Require all denied
    </FilesMatch>

    # Composer & package manager files
    <FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|yarn\.lock)$">
        Require all denied
    </FilesMatch>

    # PHP config files
    <FilesMatch "^(php\.ini|\.user\.ini|\.htpasswd)$">
        Require all denied
    </FilesMatch>

    # Build/deploy/debug scripts — blok akses dari web
    <FilesMatch "^(install\.php|deploy-check\.php|phpinfo\.php|probe\.php)$">
        Require all denied
    </FilesMatch>

    # QA config files
    <FilesMatch "^(phpstan\.neon|phpunit\.xml|\.phpcs\.xml|\.php-cs-fixer)">
        Require all denied
    </FilesMatch>

    # SQL schema
    <FilesMatch "^schema\.sql$">
        Require all denied
    </FilesMatch>

    # Blok ekstensi berbahaya (defense in depth)
    <FilesMatch "\.(phtml|pht|php3|php4|php5|phps|cgi|pl|py|sh|bash)$">
        Require all denied
    </FilesMatch>
</IfModule>

# Fallback untuk Apache < 2.4
<IfModule !mod_authz_core.c>
    <FilesMatch "^\.">
        Order deny,allow
        Deny from all
    </FilesMatch>
</IfModule>

# ── ERROR DOCUMENTS ──────────────────────────────────────────────
ErrorDocument 403 "403 Forbidden"
ErrorDocument 404 "404 Not Found"
ErrorDocument 500 "500 Internal Server Error"
