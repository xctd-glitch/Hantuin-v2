# ===================================================================
# SRP v2.1 — public_html/.htaccess
# ===================================================================
# Web root configuration untuk Apache / LiteSpeed.
# Handles: security headers, caching, compression, routing, CORS,
#          Content-Type fix (415 prevention), trusted proxy support.
# ===================================================================

# ── BASIC OPTIONS ────────────────────────────────────────────────
Options -Indexes
Options -MultiViews
DirectoryIndex index.php

# ── PHP SETTINGS (shared hosting override) ───────────────────────
<IfModule mod_php.c>
    php_value max_execution_time 30
    php_value memory_limit 128M
    php_value post_max_size 8M
    php_value upload_max_filesize 2M
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>

# ── CONTENT TYPE — cegah 415 Unsupported Media Type ──────────────
# LiteSpeed/OpenResty kadang reject request ke .php jika Content-Type
# tidak dikenali. Pastikan .php selalu diproses sebagai PHP.
<IfModule mod_mime.c>
    AddType application/x-httpd-php .php
    AddType application/x-httpd-php-source .phps
</IfModule>

# Force handler untuk PHP (LiteSpeed compatibility)
<FilesMatch "\.php$">
    <IfModule mod_proxy_fcgi.c>
        SetHandler "proxy:unix:/var/run/php-fpm.sock|fcgi://localhost"
    </IfModule>
    <IfModule !mod_proxy_fcgi.c>
        SetHandler application/x-httpd-php
    </IfModule>
</FilesMatch>

# ── SECURITY HEADERS ─────────────────────────────────────────────
<IfModule mod_headers.c>
    # Clickjacking protection
    Header always set X-Frame-Options "DENY"

    # MIME type sniffing protection
    Header always set X-Content-Type-Options "nosniff"

    # XSS protection (legacy browsers)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy (disable unused browser features)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

    # HSTS — force HTTPS (uncomment di production)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Hapus header server info (jika bisa)
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ── CACHING ──────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # PHP responses: no cache
    <FilesMatch "\.(php)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Static assets: cache 1 year
    <FilesMatch "\.(jpe?g|png|gif|ico|webp|avif|css|js|woff2?|ttf|eot|otf|svg)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Service worker: no cache (harus selalu fresh)
    <FilesMatch "service-worker\.js$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    </FilesMatch>

    # Manifest: cache 1 day
    <FilesMatch "manifest\.json$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>

# ── COMPRESSION ──────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE \
        text/html \
        text/plain \
        text/xml \
        text/css \
        text/javascript \
        application/javascript \
        application/json \
        application/xml \
        application/xhtml+xml \
        image/svg+xml \
        font/woff2 \
        font/woff
</IfModule>

# LiteSpeed compression (jika mod_deflate tidak ada)
<IfModule LiteSpeed>
    CacheDisable public /api/
    CacheDisable public /decision.php
    CacheDisable public /postback.php
</IfModule>

# ── CORS — untuk API endpoints ───────────────────────────────────
<IfModule mod_headers.c>
    <FilesMatch "(api|decision|postback|data)\.php$">
        Header always set Access-Control-Allow-Origin "*"
        Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Header always set Access-Control-Allow-Headers "Content-Type, X-API-Key, X-Requested-With, Authorization"
        Header always set Access-Control-Max-Age "3600"
    </FilesMatch>
</IfModule>

# Handle preflight OPTIONS request
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(api|decision|postback|data)\.php$ - [R=204,L]
</IfModule>

# ── URL REWRITING / ROUTING ──────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ─── Security: blok akses ke direktori sensitif ───
    RewriteRule ^(?:\.git|\.svn|\.hg)/ - [F,L]
    RewriteRule ^(?:src|cron|backups|logs|storage|vendor)/ - [F,L]
    RewriteRule ^(?:node_modules|\.claude)/ - [F,L]

    # ─── Force HTTPS (uncomment di production) ───
    # RewriteCond %{HTTPS} !=on
    # RewriteCond %{HTTP:X-Forwarded-Proto} !https
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ─── API routing ───
    # /api/v1/{endpoint} → api.php with PATH_INFO
    RewriteRule ^api/v1/?(.*)$ api.php/$1 [L,QSA]

    # ─── Campaign short URLs ───
    # /l/campaignname → landing.php?user_lp=campaignname
    RewriteRule ^l/([a-zA-Z0-9_-]+)/?$ landing.php?user_lp=$1 [L,QSA]

    # ─── Meetup tracking entry ───
    RewriteRule ^_meetups/?$ landing.php [L,QSA]

    # ─── Clean URL aliases ───
    RewriteRule ^login/?$ login.php [L,QSA]
    RewriteRule ^landing/?$ landing.php [L,QSA]
    RewriteRule ^stats/?$ stats.php [L,QSA]
    RewriteRule ^decision/?$ decision.php [L,QSA]
    RewriteRule ^postback/?$ postback.php [L,QSA]

    # ─── Root ───
    RewriteRule ^$ index.php [L,QSA]

    # ─── Serve real files/directories as-is ───
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ─── Catch-all: 404 (uncomment untuk front controller) ───
    # RewriteRule ^(.+)$ index.php [L,QSA]
</IfModule>

# ── DENY ACCESS TO SENSITIVE FILES ───────────────────────────────
<IfModule mod_authz_core.c>
    # .env files
    <FilesMatch "^\.env">
        Require all denied
    </FilesMatch>

    # Hidden files (dotfiles)
    <FilesMatch "^\.">
        Require all denied
    </FilesMatch>

    # Backup & temp files
    <FilesMatch "\.(bak|backup|old|tmp|swp|swo|dist|orig|save)$">
        Require all denied
    </FilesMatch>

    # Composer files
    <FilesMatch "^(composer\.(json|lock))$">
        Require all denied
    </FilesMatch>

    # PHP config files
    <FilesMatch "^(php\.ini|\.user\.ini|\.htpasswd)$">
        Require all denied
    </FilesMatch>

    # Build/deploy scripts (harus dihapus setelah install)
    <FilesMatch "^(install\.php|deploy-check\.php|phpinfo\.php)$">
        Require all denied
    </FilesMatch>

    # SQL schema
    <FilesMatch "^schema\.sql$">
        Require all denied
    </FilesMatch>
</IfModule>

# Fallback untuk Apache < 2.4
<IfModule !mod_authz_core.c>
    <FilesMatch "^\.">
        Order deny,allow
        Deny from all
    </FilesMatch>
</IfModule>

# ── ERROR DOCUMENTS ──────────────────────────────────────────────
ErrorDocument 403 "403 Forbidden"
ErrorDocument 404 "404 Not Found"
ErrorDocument 500 "500 Internal Server Error"
