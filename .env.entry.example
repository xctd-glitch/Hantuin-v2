# =============================================================================
# Hantuin-v2 Entry Point — Environment Configuration
# =============================================================================
# Taruh file ini sebagai .env di direktori yang sama dengan entry.php.
#
# Copy file ini:
#   cp .env.entry.example .env
#
# Lalu isi value di bawah.
# =============================================================================

# URL endpoint decision di server Hantuin-v2 (WAJIB)
# Format: https://<domain-brand>/api/v1/decision
HANTUIN_API_URL=https://hantuin.com/api/v1/decision

# API Key dari dashboard Hantuin-v2 → Settings → API Key (WAJIB)
HANTUIN_API_KEY=

# Fallback path jika decision gagal (default: /_meetups/)
FALLBACK_PATH=/_meetups/

# Timeout koneksi ke API (detik)
API_TIMEOUT=5
API_CONNECT_TIMEOUT=3

# Cache decision (detik). 0 = nonaktif.
DECISION_CACHE_TTL=3
# DECISION_CACHE_DIR=/tmp/hantuin_cache
