# =============================================
# Hantuin-v2 Decision Logic — Environment Template
# =============================================

# Environment: production | staging | development
SRP_ENV=production
# Or point directly to a file (relative to project root or absolute path)
SRP_ENV_FILE=

# Admin dashboard username
SRP_ADMIN_USER=admin

# Password hash generated with:
# php -r "echo password_hash('ganti_password', PASSWORD_DEFAULT), PHP_EOL;"
SRP_ADMIN_PASSWORD_HASH=

# Plain text password (fallback when HASH is empty — dev/testing convenience)
SRP_ADMIN_PASSWORD=

# Read-only dashboard user
SRP_USER_USER=
SRP_USER_PASSWORD_HASH=
SRP_USER_PASSWORD=

# API key for /decision.php and public API
# Generate with: openssl rand -hex 32
SRP_API_KEY=changeme-secure-key
# Integration HTTP timeout in seconds (end-to-end)
SRP_API_TIMEOUT=10
# Integration connect timeout in seconds
SRP_API_CONNECT_TIMEOUT=3
# Cooldown in seconds after network timeout/error to prevent repeated cURL stalls
SRP_API_FAILURE_COOLDOWN=30
# Maximum retry count for retryable API failures (429/5xx/network)
SRP_API_MAX_RETRIES=0
# Exponential backoff base delay in milliseconds
SRP_API_BACKOFF_BASE_MS=250
# Exponential backoff max delay in milliseconds
SRP_API_BACKOFF_MAX_MS=1500
# Cache identical API responses for this many seconds
SRP_API_RESPONSE_CACHE_SECONDS=3
# Wait this long for an identical in-flight request before sending a duplicate
SRP_API_INFLIGHT_WAIT_MS=300
# Comma-separated trusted proxy CIDRs (only these sources may provide client-IP headers)
# Default: Cloudflare IPv4 + IPv6 ranges (https://www.cloudflare.com/ips/)
SRP_TRUSTED_PROXIES=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22,2400:cb00::/32,2606:4700::/32,2803:f800::/32,2405:b500::/32,2405:8100::/32,2a06:98c0::/29,2c0f:f248::/32
# Public API rate-limit (per client IP + endpoint)
SRP_PUBLIC_API_RATE_WINDOW=60
SRP_PUBLIC_API_RATE_MAX=120
# Heavy endpoints (logs, analytics, conversions) get a stricter limit
SRP_PUBLIC_API_RATE_HEAVY_MAX=30

# Cache backend — driver: redis | memcached | apcu | none  (auto-detect when unset)
CACHE_DRIVER=
CACHE_PREFIX=srp_
# Redis (used when CACHE_DRIVER=redis or auto-detected)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Memcached (used when CACHE_DRIVER=memcached)
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

# Optional proxy to call decision logic hosted elsewhere
# Example: https://host-a.example.com/decision.php
SRP_REMOTE_DECISION_URL=
# Leave empty to reuse SRP_API_KEY, otherwise set upstream key here
SRP_REMOTE_API_KEY=

# Database connection (MySQL / MariaDB)
SRP_DB_HOST=127.0.0.1
SRP_DB_PORT=3306
SRP_DB_NAME=
SRP_DB_USER=
SRP_DB_PASS=
SRP_DB_SOCKET=

# Full public URL of this app (used for Host header in loopback API tests)
# Example: https://example.com or https://host-a.example.com
APP_URL=

# Application environment for SSL/cookie behavior
# Set to 'production' or 'true' to enforce secure cookies
APP_ENV=production
SRP_FORCE_SECURE_COOKIES=true
